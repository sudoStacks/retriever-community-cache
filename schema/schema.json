{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://retreivr.dev/schemas/community-index/recording-source-map.schema.json",
  "title": "Retreivr Community Index Recording Source Map",
  "description": "Maps a canonical MusicBrainz recording MBID to one or more transport source candidates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "recording_mbid",
    "updated_at",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for this record format."
    },
    "recording_mbid": {
      "type": "string",
      "description": "MusicBrainz recording MBID (UUID).",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "updated_at": {
      "type": "string",
      "description": "Last time this record was updated by a publisher.",
      "format": "date-time"
    },
    "sources": {
      "type": "array",
      "description": "Candidate transport sources for this recording.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/youtubeSource"
      }
    }
  },
  "$defs": {
    "youtubeSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "video_id",
        "source",
        "confidence",
        "last_verified_at"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "youtube"
          ]
        },
        "video_id": {
          "type": "string",
          "description": "YouTube video identifier.",
          "pattern": "^[A-Za-z0-9_-]{11}$"
        },
        "duration_ms": {
          "type": "integer",
          "description": "Expected duration in milliseconds.",
          "minimum": 1,
          "maximum": 7200000
        },
        "candidate_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "candidate_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "duration_delta_ms": {
          "type": [
            "integer",
            "null"
          ]
        },
        "retreivr_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_verified_at": {
          "type": "string",
          "description": "Date this source mapping was last verified.",
          "format": "date-time"
        },
        "verified_by": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
